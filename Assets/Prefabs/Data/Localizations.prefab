--- !u!114 &646380366877644078
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1256838727060420908}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: eb15fa0e7301ff849bf4d6dcede7c12b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  data: 0
  entries:
  - Language: English
    Text: "The sound grew louder\u2026 what ahead could be?\r\nThe crunch of bones,
      the clang of steel \u2014 no way to turn and flee.\n<page>He looked at fear
      \u2014 the brave sir knight,\r\nFor there was nowhere left to hide..."
    Object: {fileID: 0}
  - Language: Russian
    Text: "\u0412\u0441\u0451 \u0433\u0440\u043E\u043C\u0447\u0435 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0441\u044F
      \u0437\u0432\u0443\u043A\u2026 \u0447\u0442\u043E \u0442\u0430\u043C, \u0432\u043E
      \u043C\u0433\u043B\u0435?\r\n\u041C\u0435\u0442\u0430\u043B\u0430 \u0437\u0432\u043E\u043D\u043A\u0438\u0439
      \u043B\u044F\u0437\u0433 \u0438 \u0433\u0440\u0443\u0431\u044B\u0439 \u0445\u0440\u0443\u0441\u0442
      \u043A\u043E\u0441\u0442\u0435\u0439.\n<page>\u0410 \u043E\u043D \u043B\u0438\u0448\u044C
      \u0432 \u043E\u0447\u0438 \u0441\u0442\u0440\u0430\u0445\u0443 \u0433\u0440\u043E\u0437\u043D\u043E
      \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u043B,\n\u0418 \u0441\u0436\u0430\u043B
      \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u0441\u0438\u043B \u043E\u043D
      \u043C\u0435\u0447 \u0440\u0443\u043A\u043E\u0439 \u0441\u0432\u043E\u0435\u0439..."
    Object: {fileID: 0}
