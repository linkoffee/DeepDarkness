  m_EditorClassIdentifier: 
  data: 0
  entries:
  - Language: English
    Text: '> ==========================

      > The knight''s soul left him

      >
      Try to start all over again...'
    Object: {fileID: 0}
  - Language: Russian
    Text: "> ==========================\n> \u0414\u0443\u0448\u0430 \u0440\u044B\u0446\u0430\u0440\u044F
      \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E \u043F\u043E\u043A\u0438\u043D\u0443\u043B\u0430
      \u0442\u0435\u043B\u043E\n> \u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435
      \u043D\u0430\u0447\u0430\u0442\u044C \u0437\u0430\u043D\u043E\u0432\u043E..."
    Object: {fileID: 0}
