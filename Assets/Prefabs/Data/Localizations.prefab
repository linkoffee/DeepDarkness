  m_EditorClassIdentifier: 
  data: 0
  entries:
  - Language: English
    Text: '> ============================================

      > The knight hit
      his head hard on the obstacle

      > He can no longer continue on his way

      >
      Try to start all over again...'
    Object: {fileID: 0}
  - Language: Russian
    Text: "> ============================================\n> \u0420\u044B\u0446\u0430\u0440\u044C
      \u0441\u0438\u043B\u044C\u043D\u043E \u0443\u0434\u0430\u0440\u0438\u043B\u0441\u044F
      \u043E\u0431 \u043F\u0440\u0435\u043F\u044F\u0442\u0441\u0442\u0432\u0438\u0435\n>
      \u041E\u043D \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
      \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0442\u044C \u0441\u0432\u043E\u0439
      \u043F\u0443\u0442\u044C\n> \u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435
      \u043D\u0430\u0447\u0430\u0442\u044C \u0437\u0430\u043D\u043E\u0432\u043E..."
    Object: {fileID: 0}
