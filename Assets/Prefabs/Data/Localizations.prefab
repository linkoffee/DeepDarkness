      name=\"SlimePortrait\">\n\n\n<page>\n<style=\"h3\">\u0417\u0434\u043E\u0440\u043E\u0432\u044C\u0435:
      <style=\"Health\">{slime_health}</style></style>\n<style=\"h3\">\u0423\u0440\u043E\u043D:
