--- !u!114 &6675774069181831657
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4078183786077877452}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: eb15fa0e7301ff849bf4d6dcede7c12b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  data: 0
  entries:
  - Language: English
    Text: "And one more bloodthirsty monster appears,\r\nRight there on your path
      \u2014 to feed on your fears.\r..\n<page>The gnash of its teeth cuts the ear
      like a knife,\r\nAnd it sees with the malice of its single eye\u2019s strife"
    Object: {fileID: 0}
  - Language: Russian
    Text: "\u0410\u0445 \u0432\u043E\u0442 \u0435\u0449\u0451 \u0442\u0432\u0430\u0440\u044C
      \u2014 \u043A\u0440\u043E\u0432\u043E\u0436\u0430\u0434\u043D\u0435\u0439,
      \u0441\u0442\u0440\u0430\u0448\u043D\u0435\u0439,\n\u041F\u0435\u0440\u0435\u043A\u0440\u044B\u043B\u0430
      \u0432\u0430\u043C \u043F\u0443\u0442\u044C \u0441\u0440\u0435\u0434\u044C
      \u043F\u043E\u0434\u0437\u0435\u043C\u043D\u044B\u0445 \u0442\u0435\u043D\u0435\u0439...\n<page>\u0421\u043A\u0440\u0435\u0436\u0435\u0442
      \u043A\u043B\u044B\u043A\u043E\u0432 \u0440\u0435\u0436\u0435\u0442 \u0441\u043B\u0443\u0445,
      \u043A\u0430\u043A \u043A\u043B\u0438\u043D\u043E\u043A,\n\u0418 \u0432\u0433\u043B\u044F\u0434\u043E\u043C
      \u043F\u0440\u043E\u043D\u0437\u0430\u0435\u0442, \u043A\u0430\u043A \u0441\u043C\u0435\u0440\u0442\u0438
      \u043D\u0430\u043C\u0451\u043A"
    Object: {fileID: 0}
