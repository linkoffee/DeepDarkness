--- !u!114 &3146979361932859075
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4022931251634617380}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: eb15fa0e7301ff849bf4d6dcede7c12b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  data: 0
  entries:
  - Language: English
    Text: "<style=\"h1\">The Book of Knowledge</style>\r\n\r\n\r\n\r\n<style=\"h3\">Written
      by:</style>\r\n\r\n<u><align=center>Sir Vant the Rhymeless</align></u>\r\n\r\n<page><size=0.8em><align=center>\xAB
      Entombed in darkness, without light,\r\nNo savior comes to claim the fight,\r\nOh
      Lord, why did you bring me here,\r\nTo drown in sorrow, pain, and fear? \xBB</align>\r\n\r\nGot
      paper, ink \u2014 I'm safe and sound,\r\nAnd now a rhyme must be found...\r\n\r\n<sprite
      name=\"BookAndInk\">\r\n\r\n<page><style=\"h2\">Terminal Guide</style>\r\n\r\n<sprite=\"TerminalGuide\"
      name=\"TerminalGuide\">\r\n\r\n<page><size=0.8em>The terminal is the game's
      main tool. It allows you to make the knight perform certain actions, restart
      a level if something goes wrong, and even open the book you're currently reading.\r\n\r\nWrite
      your code in the <u><b>Code Area</b></u>, then run it by clicking the <u><b>Run
      Commands</b></u> button. You'll see errors, warnings, and information in the
      <b><u>Output Area</b></u>. If anything goes wrong, don't hesitate to click
      the <b><u>Restart Level</b></u> button. \r\n</size>\r\n\r\n<page><style=\"h2\">How
      to move?</style>\r\n\r\n\r\n<sprite name=\"GuideMoveUp\"><sprite name=\"GuideMoveRight\">\r\n<sprite
      name=\"GuideMoveLeft\"><sprite name=\"GuideMoveDown\">\r\n\r\n<page><size=0.7em><align=center>\xAB
      We always must be moving towards something, you will see,\r\nFor without it,
      we're stuck, and we will not become free... \xBB</align>\r\n\r\nEnter the following
      commands in the terminal to see how the knight moves.\r\n<#001891>Steps</color>
      are integer values, such as <#001891>1, 2, 3, 5, 10.</color>\r\n\r\n<style=\"Command\"><color=black>Knight</color>.MoveUp(<#001891>steps</color>)</style>\r\n<style=\"Command\"><color=black>Knight</color>.MoveRight(<#001891>steps</color>)</style>\r\n<style=\"Command\"><color=black>Knight</color>.MoveLeft(<#001891>steps</color>)</style>\r\n<style=\"Command\"><color=black>Knight</color>.MoveDown(<#001891>steps</color>)</style>"
    Object: {fileID: 0}
  - Language: Russian
    Text: "<style=\"h1\">\u041A\u043D\u0438\u0433\u0430 \u0437\u043D\u0430\u043D\u0438\u0439</style>\r\n\r\n\r\n\r\n<style=\"h3\">\u0410\u0432\u0442\u043E\u0440:</style>\r\n\r\n<u><align=center>\u0421\u044D\u0440
      \u0412\u0430\u043D\u0442 \u0420\u0438\u0444\u043C\u043E\u043F\u043B\u0451\u0442</align></u>\r\n\r\n<page><size=0.8em><align=center>\xAB
      \u0412\u043E \u043C\u0440\u0430\u043A\u0435 \u0441\u043A\u043E\u0432\u0430\u043D,
      \u0441\u0432\u0435\u0442 \u043F\u043E\u0433\u0430\u0441,\r\n\u0421\u043F\u0430\u0441\u0438\u0442\u0435\u043B\u044C
      \u043D\u0435 \u043F\u0440\u0438\u0434\u0451\u0442 \u0432 \u0441\u0435\u0439
      \u0447\u0430\u0441.\r\n\u0417\u0430\u0447\u0435\u043C, \u0413\u043E\u0441\u043F\u043E\u0434\u044C,
      \u044F \u0437\u0434\u0435\u0441\u044C, \u0432\u043E \u0442\u044C\u043C\u0435,\r\n\u0412
      \u0441\u043B\u0435\u0437\u0430\u0445, \u0432 \u0442\u043E\u0441\u043A\u0435,
      \u0432 \u0433\u043B\u0443\u0445\u043E\u0439 \u0442\u044E\u0440\u044C\u043C\u0435?
      \xBB</align>\r\n\r\n\u0427\u0435\u0440\u043D\u0438\u043B\u0430 \u0438 \u0431\u0443\u043C\u0430\u0433\u0430
      \u0435\u0441\u0442\u044C \u2014 \u0438 \u044F \u0433\u043E\u0442\u043E\u0432,\r\n\u041E\u0441\u0442\u0430\u043B\u043E\u0441\u044C
      \u043F\u043E\u0434\u043E\u0431\u0440\u0430\u0442\u044C \u043B\u0438\u0448\u044C
      \u043F\u0430\u0440\u0443 \u0441\u043B\u043E\u0432...\n\r\n<sprite name=\"BookAndInk\">\r\n\r\n<page><style=\"h2\">\u0422\u0435\u0440\u043C\u0438\u043D\u0430\u043B?</style>\r\n\r\n<sprite=\"TerminalGuide\"
      name=\"TerminalGuide\">\r\n\r\n<page><size=0.8em>\u0422\u0435\u0440\u043C\u0438\u043D\u0430\u043B
      \u2014 \u044D\u0442\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442
      \u0438\u0433\u0440\u044B. \u041E\u043D \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
      \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0442\u044C \u0440\u044B\u0446\u0430\u0440\u0435\u043C,
      \u043F\u0435\u0440\u0435\u0437\u0430\u043F\u0443\u0441\u043A\u0430\u0442\u044C
      \u0443\u0440\u043E\u0432\u0435\u043D\u044C, \u0435\u0441\u043B\u0438 \u0447\u0442\u043E-\u0442\u043E
      \u043F\u043E\u0448\u043B\u043E \u043D\u0435 \u0442\u0430\u043A, \u0438 \u0434\u0430\u0436\u0435
      \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0442\u044C \u043A\u043D\u0438\u0433\u0443,
      \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0432\u044B \u0441\u0435\u0439\u0447\u0430\u0441
      \u0447\u0438\u0442\u0430\u0435\u0442\u0435.\n\n\u0412\u0432\u0435\u0434\u0438\u0442\u0435
      \u0441\u0432\u043E\u0439 \u043A\u043E\u0434 \u0432 <u><b>Code Area</b></u>,
      \u0437\u0430\u0442\u0435\u043C \u0437\u0430\u043F\u0443\u0441\u0442\u0438\u0442\u0435
      \u0435\u0433\u043E, \u043D\u0430\u0436\u0430\u0432 \u043A\u043D\u043E\u043F\u043A\u0443
      <u><b>Run Commands</b></u>. \u0412\u044B \u0443\u0432\u0438\u0434\u0438\u0442\u0435
      \u043E\u0448\u0438\u0431\u043A\u0438, \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u044F
      \u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E \u0432
      <b><u>Output Area</b></u>. \u0415\u0441\u043B\u0438 \u0447\u0442\u043E-\u0442\u043E
      \u043F\u043E\u0439\u0434\u0451\u0442 \u043D\u0435 \u0442\u0430\u043A, \u043D\u0435
      \u0441\u0442\u0435\u0441\u043D\u044F\u0439\u0442\u0435\u0441\u044C \u043D\u0430\u0436\u0430\u0442\u044C
      \u043A\u043D\u043E\u043F\u043A\u0443 <b><u>Restart Level</b></u>.\n</size>\n\r\n<page><style=\"h2\">\u041A\u0430\u043A
      \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F?</style>\r\n\r\n\r\n<sprite
      name=\"GuideMoveUp\"><sprite name=\"GuideMoveRight\">\r\n<sprite name=\"GuideMoveLeft\"><sprite
      name=\"GuideMoveDown\">\r\n\r\n<page><size=0.7em><align=center>\xAB \u0412\u0441\u0435\u0433\u0434\u0430
      \u043A \u0447\u0435\u043C\u0443-\u0442\u043E \u043D\u0430\u0434\u043E \u043D\u0430\u043C
      \u0438\u0434\u0442\u0438,\r\n\u0411\u0435\u0437 \u0446\u0435\u043B\u0438 \u043D\u0430\u043C
      \u0441\u0432\u043E\u0431\u043E\u0434\u044B \u043D\u0438\u043A\u043E\u0433\u0434\u0430
      \u043D\u0435 \u043E\u0431\u0440\u0435\u0441\u0442\u0438... \xBB</align>\r\n\r\n\u0412\u0432\u0435\u0434\u0438\u0442\u0435
      \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0435 \u043A\u043E\u043C\u0430\u043D\u0434\u044B
      \u0432 \u0442\u0435\u0440\u043C\u0438\u043D\u0430\u043B\u0435, \u0447\u0442\u043E\u0431\u044B
      \u0443\u0432\u0438\u0434\u0435\u0442\u044C, \u043A\u0430\u043A \u0440\u044B\u0446\u0430\u0440\u044C
      \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F.\n<#001891>\u0413\u0434\u0435
      \u0428\u0410\u0413\u0418</color> \u2014 \u043A\u043E\u043B-\u0432\u043E \u0448\u0430\u0433\u043E\u0432,
      \u044D\u0442\u043E \u0446\u0435\u043B\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0435
      \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
      <#001891>1, 2, 3, 5, 10.</color>\n\n<style=\"Command\"><color=black>Knight</color>.MoveUp(<#001891>\u0428\u0410\u0413\u0418</color>)</style>\n<style=\"Command\"><color=black>Knight</color>.MoveRight(<#001891>\u0428\u0410\u0413\u0418</color>)</style>\n<style=\"Command\"><color=black>Knight</color>.MoveLeft(<#001891>\u0428\u0410\u0413\u0418</color>)</style>\n<style=\"Command\"><color=black>Knight</color>.MoveDown(<#001891>\u0428\u0410\u0413\u0418</color>)</style>"
    Object: {fileID: 0}
