  m_EditorClassIdentifier: 
  data: 0
  entries:
  - Language: English
    Text: '<style="h2">{ashtor_name}</style>



      <sprite="Book_Content_Sprite_Asset_2"
      name="AshtorPortrait">



      <page>

      <style="h3">Health: <style="Health">{ashtor_health}</style></style>

      <style="h3">Damage:
      <style="Damage">{ashtor_damage}</style></style>



      <size=1em>{ashtor_desc}</size>'
    Object: {fileID: 0}
  - Language: Russian
    Text: "<style=\"h2\">{ashtor_name}</style>\r\n\r\n<sprite=\"Book_Content_Sprite_Asset_2\"
      name=\"AshtorPortrait\">\r\n\r\n<page>\r\n<style=\"h3\">\u0417\u0434\u043E\u0440\u043E\u0432\u044C\u0435:
      <style=\"Health\">{ashtor_health}</style></style>\r\n<style=\"h3\">\u0423\u0440\u043E\u043D:
      <style=\"Damage\">{ashtor_damage}</style></style>\r\n\r\n<size=1em>{ashtor_desc}</size>"
    Object: {fileID: 0}
