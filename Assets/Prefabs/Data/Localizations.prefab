--- !u!114 &8515798169292264261
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7282715463425786137}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: eb15fa0e7301ff849bf4d6dcede7c12b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  data: 0
  entries:
  - Language: English
    Text: 'Once, lost on his path, far from heaven''s clear ray,

      A wandering
      knight, bolder far than the fray,

      <page>Strayed into a fortress deep
      under the ground,

      Where sunlight had perished, and silence was crowned.

      <page>And
      suddenly creak tore the air behind,

      The gates shut at once and the light
      went blind

      <page>The knight then perceived he''d been captured within,

      He''ll
      have to break through darkness for light to begin...'
    Object: {fileID: 0}
  - Language: Russian
    Text: "\u041E\u0434\u043D\u0430\u0436\u0434\u044B \u0437\u0430\u0431\u0440\u0451\u043B
      \u043F\u043E \u043E\u0448\u0438\u0431\u043A\u0435 \u0441\u0432\u043E\u0435\u0439,\n\u0411\u043B\u0443\u0436\u0434\u0430\u044E\u0449\u0438\u0439
      \u0440\u044B\u0446\u0430\u0440\u044C, \u0434\u0440\u0443\u0433\u0438\u0445
      \u0432\u0441\u0435\u0445 \u0441\u043C\u0435\u043B\u0435\u0439,\n<page>\u0412
      \u043F\u043E\u0434\u0437\u0435\u043C\u043D\u0443\u044E \u043A\u0440\u0435\u043F\u043E\u0441\u0442\u044C,
      \u0433\u0434\u0435 \u0441\u0432\u0435\u0442 \u043D\u0435 \u043F\u0440\u043E\u043D\u0438\u043A\n\u0413\u0434\u0435
      \u043C\u0451\u0440\u0442\u0432\u044B\u0435 \u0441\u0442\u0435\u043D\u044B \u0445\u0440\u0430\u043D\u044F\u0442
      \u043D\u0435\u043C\u043E\u0439 \u043B\u0438\u043A...\n<page>\u0418 \u0432\u0434\u0440\u0443\u0433
      \u0437\u0430 \u0441\u043F\u0438\u043D\u043E\u0439 \u0441\u0442\u0440\u0430\u0448\u043D\u044B\u0439
      \u0441\u043A\u0440\u0438\u043F \u043F\u0440\u043E\u0437\u0432\u0443\u0447\u0430\u043B,\r\n\u0412\u0440\u0430\u0442\u0430
      \u0432\u0434\u0440\u0443\u0433 \u0437\u0430\u043A\u0440\u044B\u043B\u0438\u0441\u044C
      \u0438 \u0441\u0432\u0435\u0442 \u0437\u0430\u043C\u043E\u043B\u0447\u0430\u043B,\r\n<page>\u0422\u0443\u0442
      \u043F\u043E\u043D\u044F\u043B \u0440\u044B\u0446\u0430\u0440\u044C - \u043F\u043E\u043F\u0430\u043B
      \u043E\u043D \u0432 \u0431\u0435\u0434\u0443,\r\n\u041F\u0440\u0438\u0434\u0451\u0442\u0441\u044F
      \u043F\u0440\u043E\u0440\u044B\u0432\u0430\u0442\u044C\u0441\u044F \u043A \u0441\u0432\u0435\u0442\u0443
      \u0447\u0435\u0440\u0435\u0437 \u0442\u0435\u043C\u043D\u043E\u0442\u0443"
    Object: {fileID: 0}
