--- !u!114 &2316385907043035469
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 751873509885083989}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: eb15fa0e7301ff849bf4d6dcede7c12b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  data: 0
  entries:
  - Language: English
    Text: 'A hungry gaze, fangs out like sabers,

      He smells your scent from
      miles away.

      <page>No deadlier beast in this world''s layers,

      Red-eyed
      bloodsucker standing on your way.'
    Object: {fileID: 0}
  - Language: Russian
    Text: "\u0413\u043E\u043B\u043E\u0434\u043D\u044B\u0439 \u0432\u0437\u0433\u043B\u044F\u0434,
      \u043A\u043B\u044B\u043A\u0438 \u2014 \u043A\u0430\u043A \u0441\u0430\u0431\u043B\u0438,\r\n\u0422\u0432\u043E\u0439
      \u0437\u0430\u043F\u0430\u0445 \u0447\u0443\u0435\u0442 \u0437\u0430 \u0432\u0435\u0440\u0441\u0442\u0443.\r\n<page>\u041D\u0435\u0442
      \u0442\u0432\u0430\u0440\u0438 \u0437\u043B\u0435\u0439 \u0432\u043E \u0442\u044C\u043C\u0435
      \u043F\u043E\u0434\u0437\u0435\u043C\u043D\u043E\u0439,\r\n\u0427\u0435\u043C
      \u043A\u0440\u043E\u0432\u043E\u043F\u0438\u0439\u0446\u0430, \u0432\u0441\u0442\u0430\u0432\u0448\u0438\u0439
      \u043D\u0430 \u0442\u0440\u043E\u043F\u0443."
    Object: {fileID: 0}
