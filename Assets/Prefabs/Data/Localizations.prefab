--- !u!114 &1521056870112599454
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 8864733494839633991}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: eb15fa0e7301ff849bf4d6dcede7c12b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  data: 0
  entries:
  - Language: English
    Text: "<style=\"h2\">How to attack?</style>\r\n\r\n<sprite name=\"GuideAttack\">\r\n\r\n<page><size=0.7em><align=center>\xAB
      One, two, three, four, five, six, seven,\r\nI will crush all foes, by heaven!
      \xBB</align>\r\n\r\nEnter the following commands in the terminal to crush the
      enemy in your path.\r\n\r\n<style=\"Command\"><color=black>Knight</color>.Attack()</style>\r\n\r\n<page><style=\"h2\">How
      to block?</style>\r\n\r\n<sprite name=\"GuideBlock\">\r\n\r\n<page><size=0.7em><align=center>\xAB
      I need no shield \u2014 that useless stuff,\r\nWith my own blade, I'll block
      enough! \xBB</align>\r\n\r\nEnter the following commands in the terminal to
      repel an enemy attack.\r\n\r\n<style=\"Command\"><color=black>Knight</color>.Block()</style>\r\n\r\n<page><style=\"h1\">Dungearium</style>\r\n\r\n<style=\"h4\">Description
      of the creatures that live down here (very dangerous)</style>\r\n\r\n<size=0.7em><align=center>\xAB
      All kinds of beasts dwell down below,\r\nNo guests they expected, that's for
      sure.\r\nDangerous monsters have lived here along,\r\nI won't be their dinner
      \u2014 I`m not tasty at all! \xBB</align>\r\n\r\n<page>\r\n<br>\r\n<br>\r\n<br>\r\n<style=\"h4\">Go
      to next page -></style>\r\n\r\n<page><style=\"h2\">{skeleton_name}</style>\r\n\r\n<sprite
      name=\"SkeletonPortrait\">\r\n\r\n<page>\r\n<style=\"h3\">Health: <style=\"Health\">{skeleton_health}</style></style>\r\n<style=\"h3\">Damage:
      <style=\"Damage\">{skeleton_damage}</style></style>\r\n\r\n<size=1em>{skeleton_desc}</size>"
    Object: {fileID: 0}
  - Language: Russian
    Text: "<style=\"h2\">\u041A\u0430\u043A \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u0442\u044C?</style>\r\n\r\n<sprite
      name=\"GuideAttack\">\r\n\r\n<page><size=0.7em><align=center>\xAB \u0420\u0430\u0437,
      \u0434\u0432\u0430, \u0442\u0440\u0438, \u0447\u0435\u0442\u044B\u0440\u0435,
      \u043F\u044F\u0442\u044C...\n\u041C\u0435\u0440\u0442\u0432\u0435\u0446\u043E\u0432
      \u043D\u0435 \u0441\u043E\u0441\u0447\u0438\u0442\u0430\u0442\u044C. \xBB</align>\r\n\r\n\u0412\u0432\u0435\u0434\u0438\u0442\u0435
      \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0443\u044E \u043A\u043E\u043C\u0430\u043D\u0434\u0443
      \u0432 \u0442\u0435\u0440\u043C\u0438\u043D\u0430\u043B, \u0447\u0442\u043E\u0431\u044B
      \u0441\u043E\u043A\u0440\u0443\u0448\u0438\u0442\u044C \u0432\u0440\u0430\u0433\u0430
      \u043D\u0430 \u0441\u0432\u043E\u0435\u043C \u043F\u0443\u0442\u0438.\n\r\n<style=\"Command\"><color=black>Knight</color>.Attack()</style>\r\n\r\n<page><style=\"h2\">\u041A\u0430\u043A
      \u0431\u043B\u043E\u043A\u0438\u0440\u043E\u0432\u0430\u0442\u044C?</style>\r\n\r\n<sprite
      name=\"GuideBlock\">\r\n\r\n<page><size=0.7em><align=center>\xAB \u041D\u0435
      \u043D\u0443\u0436\u0435\u043D \u0449\u0438\u0442 \u2014 \u043D\u0438\u043A\u0447\u0451\u043C\u043D\u044B\u0439
      \u0445\u043B\u0430\u043C,\r\n\u0421\u0432\u043E\u0438\u043C \u043A\u043B\u0438\u043D\u043A\u043E\u043C
      \u044F \u043E\u0442\u043E\u0431\u044C\u044E \u0432\u0441\u0451 \u0441\u0430\u043C!
      \xBB</align>\r\n\r\n\u0412\u0432\u0435\u0434\u0438\u0442\u0435 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0443\u044E
      \u043A\u043E\u043C\u0430\u043D\u0434\u0443 \u0432 \u0442\u0435\u0440\u043C\u0438\u043D\u0430\u043B,
      \u0447\u0442\u043E\u0431\u044B \u043E\u0442\u0440\u0430\u0437\u0438\u0442\u044C
      \u0430\u0442\u0430\u043A\u0443 \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u0430.\n\r\n<style=\"Command\"><color=black>Knight</color>.Block()</style>\r\n\r\n<page><style=\"h1\">\u0422\u0435\u043C\u043D\u0438\u0430\u0440\u0438\u0439</style>\r\n\r\n<style=\"h4\">\u041E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
      \u0442\u0432\u0430\u0440\u0435\u0439, \u043E\u0431\u0438\u0442\u0430\u044E\u0449\u0438\u0445
      \u0437\u0434\u0435\u0441\u044C (\u043E\u0447\u0435\u043D\u044C \u043E\u043F\u0430\u0441\u043D\u044B\u0435)</style>\r\n\r\n<size=0.7em><align=center>\xAB
      \u041C\u043E\u043D\u0441\u0442\u0440\u044B \u0432\u0441\u0435\u0445 \u0432\u0438\u0434\u043E\u0432
      \u0432\u043D\u0438\u0437\u0443 \u043E\u0431\u0438\u0442\u0430\u044E\u0442,\r\n\u0413\u043E\u0441\u0442\u0435\u0439
      \u043E\u043D\u0438 \u044F\u0432\u043D\u043E \u0442\u0443\u0442 \u043D\u0435
      \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u044E\u0442,\r\n\u0418 \u043B\u044E\u0431\u044F\u0442
      \u043E\u043D\u0438 \u0437\u0430\u043A\u0443\u0441\u0438\u0442\u044C \u043A\u043E\u0435-\u043A\u0435\u043C,\r\n\u041D\u043E
      \u044F \u043D\u0435 \u043E\u0431\u0435\u0434 \u2014 \u044F \u043D\u0435 \u0432\u043A\u0443\u0441\u043D\u044B\u0439
      \u0441\u043E\u0432\u0441\u0435\u043C! \xBB</align>\r\n\r\n<page>\r\n<br>\r\n<br>\r\n<br>\r\n<style=\"h4\">\u041A
      \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439 \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0435
      -></style>\r\n\r\n<page><style=\"h2\">{skeleton_name}</style>\r\n\r\n<sprite
      name=\"SkeletonPortrait\">\r\n\r\n<page>\r\n<style=\"h3\">\u0417\u0434\u043E\u0440\u043E\u0432\u044C\u0435:
      <style=\"Health\">{skeleton_health}</style></style>\r\n<style=\"h3\">\u0423\u0440\u043E\u043D:
      <style=\"Damage\">{skeleton_damage}</style></style>\r\n\r\n<size=1em>{skeleton_desc}</size>"
    Object: {fileID: 0}
