  m_Script: {fileID: 11500000, guid: eb15fa0e7301ff849bf4d6dcede7c12b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  data: 0
  entries:
  - Language: English
    Text: 'The deeper he treads, the more dreadful the dark,

      Where will his
      fate lead him, what is the mark?'
    Object: {fileID: 0}
  - Language: Russian
    Text: "\u0427\u0435\u043C \u0434\u0430\u043B\u044C\u0448\u0435 \u0432\u043E \u0442\u044C\u043C\u0443,
      \u0442\u0435\u043C \u0443\u0436\u0430\u0441\u043D\u0435\u0439 \u043E\u043D\u0430,\n\u041A\u0443\u0434\u0430
      \u0436 \u0437\u0430\u0432\u0435\u0434\u0451\u0442 \u0442\u0435\u0431\u044F
      \u0442\u0432\u043E\u044F \u0441\u0443\u0434\u044C\u0431\u0430?"
    Object: {fileID: 0}
